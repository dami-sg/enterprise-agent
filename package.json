{
  "name": "enterprise-agent",
  "version": "0.0.10",
  "private": true,
  "type": "module",
  "description": "Agent core module built on Vercel AI SDK v6 (ToolLoopAgent) — runtime, tools, approval, MCP, skills, sandbox, file storage. Host-agnostic.",
  "packageManager": "pnpm@11.5.1",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @enterprise-agent/agent-contract --filter @enterprise-agent/agent build && pnpm --filter @enterprise-agent/cli dev",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "lint": "biome check .",
    "format": "biome check --write .",
    "skills:install": "node scripts/install-skills.mjs",
    "clean": "pnpm -r exec rm -rf dist .turbo node_modules/.cache"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
