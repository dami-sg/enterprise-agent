{
  "name": "@dami-sg/gateway",
  "version": "0.0.12",
  "description": "Enterprise Agent Gateway shell (gateway-architecture.md): a resident multi-session headless host that bridges IM platforms (Telegram / WeChat iLink / WhatsApp) to the agent core. Zero core changes.",
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "bin": {
    "ea-gateway": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./process": {
      "types": "./dist/runtime/gateway-process.d.ts",
      "import": "./dist/runtime/gateway-process.js"
    },
    "./paths": {
      "types": "./dist/config/paths.d.ts",
      "import": "./dist/config/paths.js"
    },
    "./admin-auth": {
      "types": "./dist/accounts/admin-auth.d.ts",
      "import": "./dist/accounts/admin-auth.js"
    },
    "./version": {
      "types": "./dist/version.d.ts",
      "import": "./dist/version.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -b && node scripts/copy-bundled-skills.mjs && node scripts/copy-bundled-agents.mjs",
    "dev": "bun src/bin.ts",
    "start": "node dist/bin.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@dami-sg/agent": "workspace:*",
    "@dami-sg/agent-contract": "workspace:*",
    "@dami-sg/agent-server": "workspace:*",
    "@dami-sg/cli": "workspace:*",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
