{
  "name": "@dami-sg/agent-client",
  "version": "0.0.11",
  "description": "TypeScript client SDK for the Enterprise Agent app-server JSON-RPC protocol.",
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@dami-sg/agent-contract": "workspace:*",
    "@dami-sg/agent-server": "workspace:*",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "vitest": "^2.1.8",
    "typescript": "^5.7.2"
  }
}
