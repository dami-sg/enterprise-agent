{
  "name": "@enterprise-agent/agent-contract",
  "version": "0.0.8",
  "description": "Pure type contract for the Enterprise Agent core module (agent §6): commands, stream events, domain models. Zero runtime dependencies.",
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
